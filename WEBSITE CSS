}
.about {
    width: 100%;
    height: 700px;
    display: flex;
    justify-content: center;
    margin-top: 5%;
    
    
}
.about > .about_text {
    width: 22.5%;
    display: flex;   
    flex-direction: column;
    justify-content: center;
    row-gap: 20px;
    padding-right: 10%;
    
    
}
.about_text > h5 {
    color: rgba(0, 0, 0, 0.5);
    font-weight: 300;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}
.about_text > h2 {
    font-weight: 500;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.about_text > p {
    text-align: left;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    color: rgba(0, 0, 0, 0.5);
    line-height: 26px;
}
.about_text > button {
    width: 60%;
    height: 10%;
    background-color: whitesmoke;
    transition: 0.5s;
    color: black;
    border: none;
    padding: auto;

}
.about_text > button:hover {
    transition: 0.5s;
    cursor: pointer;
    background-color: black;
    color: white;
    transform: scale(1.2);
}
.about_text > button::after {
    content: "";
}
.about> .about_img {
    width: 40%;
    display: flex;
    align-items: center;
    padding-right: 10%;
}
.about_img > img {
    width: 706.68px;
    height: 451px;
   
}
